# Variáveis de Ambiente - API L&J

# Porta do servidor
PORT=8080

# JWT (JSON Web Token)
JWT_SECRET=chave-super-secreta-mude-para-producao-12345
JWT_EXPIRE=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/API_L&j
# Para MongoDB Atlas (cloud), use:
# MONGODB_URI=mongodb+srv://usuario:senha@cluster0.mongodb.net/api-lj?retryWrites=true&w=majority

# Ambiente
NODE_ENV=development

# CORS (domínios permitidos para Web, Flutter Web ou outras SPA)
# App Flutter Mobile/iOS NÃO usa CORS (será bloqueado pelo navigador apenas)
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# IA - Ollama (Local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# IA - Google Gemini (Fallback)
# Obtenha a chave em: https://ai.google.dev/
# Free tier: 60 requisições por minuto
GEMINI_API_KEY=sua_chave_gemini_aqui

# ===== PRODUÇÃO (Railway) =====
# NODE_ENV=production
# PORT=3000 (Railway atribui automaticamente)
# JWT_SECRET=gere-uma-chave-segura-com-crypto.randomBytes(32)
# MONGODB_URI=mongodb+srv://usuario:senha@seu-cluster.mongodb.net/api-lj
# CORS_ORIGIN=https://seu-frontend.vercel.app,https://seu-app.railway.app
# GEMINI_API_KEY=sua-chave-real-aqui